      target="_blank"
      style="
        display: inline-block;
        background-color: #FF4500;
        color: #ffffff;
        padding: 14px 28px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border-radius: 6px;
        font-family: Arial, Helvetica, sans-serif;
      "
