<tr>
  <td style="
    background-color: #1A1D24;
    padding: 20px;
    text-align: center;
    border-bottom: 2px solid #FF4500;
  ">
    {{#if logoUrl}}
      <img src="{{logoUrl}}" alt="{{companyName}}" width="120"
        style="display: block; margin: 0 auto 10px;" />
    {{/if}}

    <div style="
      color: #ffffff;
      font-size: 18px;
      font-weight: 600;
      letter-spacing: 0.5px;
    ">
      {{companyName}}
    </div>
  </td>
</tr>