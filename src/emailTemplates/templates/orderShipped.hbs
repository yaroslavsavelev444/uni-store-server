{{#extend "baseLayout" title="Заказ отправлен"}}
  {{#content "body"}}

    <tr>
      <td style="
        padding: 24px;
        font-size: 14px;
        color: #1E1E1E;
        line-height: 1.5;
      ">

        <h2 style="
          margin: 0 0 16px;
          font-size: 18px;
          font-weight: 600;
        ">
          Заказ отправлен
        </h2>

        <p style="margin: 0 0 16px;">
          Заказ №{{orderNumber}} передан в доставку.
        </p>

      </td>
    </tr>

    <!-- Доставка -->
    <tr>
      <td style="padding: 0 24px 24px 24px;">

        <table width="100%" cellpadding="0" cellspacing="0"
          style="border: 1px solid #e5e5e5; border-radius: 6px;"
        >

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Трек-номер
            </td>
            <td style="
              padding: 12px;
              font-size: 13px;
              text-align: right;
              font-family: monospace;
            ">
              {{trackingNumber}}
            </td>
          </tr>

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Служба доставки
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              {{carrier}}
            </td>
          </tr>

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Ожидаемая дата доставки
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              {{estimatedDelivery}}
            </td>
          </tr>

        </table>

      </td>
    </tr>

    <tr>
      <td style="
        padding: 16px 24px 24px 24px;
        font-size: 13px;
        color: #666;
      ">
        Для отслеживания используйте трек-номер.
      </td>
    </tr>

  {{/content}}
{{/extend}}