{{#extend "baseLayout" title="Заказ отправлен"}}
  {{#content "body"}}
    <tr>
      <td style="padding: 28px; font-family: Arial, sans-serif; background-color: #1A1D24; border-radius: 8px;">
        <h2 style="color: #FF4500; margin-bottom: 16px;">Заказ №{{order.orderNumber}} отправлен</h2>
        <p style="color: #e6e6e6; margin-bottom: 24px;">
          Ваш заказ от {{createdDate}} передан в доставку.
        </p>

        <!-- Таблица товаров -->
        <h3 style="color: #FF4500; margin: 0 0 12px;">Состав заказа</h3>
        <table style="width:100%; border-collapse: collapse; margin-bottom: 24px;">
          <thead>
            <tr style="background:#2c2f36; color:#ccc;">
              <th style="padding:10px 8px; text-align:left;">Товар</th>
              <th style="padding:10px 8px; text-align:center;">Кол-во</th>
              <th style="padding:10px 8px; text-align:right;">Цена</th>
              <th style="padding:10px 8px; text-align:right;">Сумма</th>
            </tr>
          </thead>
          <tbody>
            {{#each order.items}}
              <tr style="border-bottom:1px solid #3a3f48;">
                <td style="padding:10px 8px; color:#e6e6e6;">{{this.name}}</td>
                <td style="padding:10px 8px; text-align:center;">{{this.quantity}}</td>
                <td style="padding:10px 8px; text-align:right;">{{this.unitPrice}} {{../order.pricing.currency}}</td>
                <td style="padding:10px 8px; text-align:right;">{{this.totalPrice}} {{../order.pricing.currency}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>

        <!-- Итоговая сумма -->
        <div style="text-align:right; margin-bottom:24px; font-size:16px; font-weight:bold; color:#FF4500;">
          Итого: {{order.pricing.total}} {{order.pricing.currency}}
        </div>

        <!-- Информация об отправке -->
        <h3 style="color: #FF4500; margin: 20px 0 12px;">Информация об отправке</h3>
        <table style="width:100%; border-collapse: collapse; margin-bottom:24px;">
          <tr>
            <td style="padding:6px 0; color:#9aa0a6; width:160px;">Трек-номер</td>
            <td style="padding:6px 0; font-family: monospace;">{{trackingNumber}}</td>
          </tr>
          <tr>
            <td style="padding:6px 0; color:#9aa0a6;">Служба доставки</td>
            <td style="padding:6px 0;">{{carrier}}</td>
          </tr>
          <tr>
            <td style="padding:6px 0; color:#9aa0a6;">Ожидаемая дата</td>
            <td style="padding:6px 0;">{{estimatedDelivery}}</td>
          </tr>
        </table>

        <!-- Получатель -->
        <h3 style="color: #FF4500; margin: 20px 0 12px;">Получатель</h3>
        <table style="width:100%; border-collapse: collapse; margin-bottom:24px;">
          <tr>
            <td style="padding:6px 0; color:#9aa0a6; width:160px;">ФИО</td>
            <td style="padding:6px 0;">{{order.recipient.fullName}}</td>
          </tr>
          <tr>
            <td style="padding:6px 0; color:#9aa0a6;">Телефон</td>
            <td style="padding:6px 0;">{{order.recipient.phone}}</td>
          </tr>
          <tr>
            <td style="padding:6px 0; color:#9aa0a6;">Email</td>
            <td style="padding:6px 0;">{{order.recipient.email}}</td>
          </tr>
        </table>

        <a href="https://yourdomain.com/orders/{{order.id}}"
           style="display:inline-block; padding:10px 16px; background:#FF4500; color:#fff; text-decoration:none; border-radius:6px;">
          Отследить заказ
        </a>
      </td>
    </tr>
  {{/content}}
{{/extend}}