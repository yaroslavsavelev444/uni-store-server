{{#extend "baseLayout" title="Новый файл в заказе"}}
  {{#content "body"}}
    <tr>
      <td style="
        padding: 28px;
        font-family: Arial, sans-serif;
        background-color: #1A1D24;
        border-radius: 10px;
        color: #ffffff;
      ">

        <h2 style="
          font-size: 20px;
          margin: 0 0 14px 0;
          color: #FF4500;
          font-weight: 600;
        ">
          Новый файл в заказе №{{orderNumber}}
        </h2>

        <p style="
          font-size: 14px;
          margin: 0 0 20px 0;
          color: #d1d5db;
          line-height: 1.5;
        ">
          В заказ добавлен новый файл. Ознакомьтесь с информацией ниже.
        </p>

        <table style="
          width: 100%;
          font-size: 14px;
          color: #e5e7eb;
          border-collapse: collapse;
        ">
          <tr>
            <td style="padding: 6px 0; width: 40%; color: #9ca3af;">Название</td>
            <td style="padding: 6px 0;">{{attachment.name}}</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Тип файла</td>
            <td style="padding: 6px 0;">{{attachment.mimeType}}</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Размер</td>
            <td style="padding: 6px 0;">{{attachment.size}} байт</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Дата загрузки</td>
            <td style="padding: 6px 0;">{{attachment.uploadedAt}}</td>
          </tr>
        </table>
      </td>
    </tr>
  {{/content}}
{{/extend}}