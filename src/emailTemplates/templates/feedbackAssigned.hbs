{{#extend "baseLayout" title="Назначен фидбек"}}
  {{#content "body"}}
    <tr>
      <td style="padding: 28px; font-family: Arial, sans-serif; background-color: #1A1D24; border-radius: 8px;">

        <h2 style="color: #FF4500; font-size: 20px; margin-bottom: 16px;">
          Назначен новый фидбек
        </h2>

        <p style="color: #e6e6e6; font-size: 14px; margin-bottom: 20px;">
          {{userName}}, вам назначен фидбек для обработки.
        </p>

        <table style="width: 100%; font-size: 14px; color: #d1d1d1; margin-bottom: 24px; border-collapse: collapse;">
          <tr>
            <td style="padding: 6px 0; width: 180px; color: #9aa0a6;">Название</td>
            <td style="padding: 6px 0;">{{title}}</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9aa0a6;">Тип</td>
            <td style="padding: 6px 0;">{{type}}</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9aa0a6;">Приоритет</td>
            <td style="padding: 6px 0;">{{priority}}</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9aa0a6;">Описание</td>
            <td style="padding: 6px 0;">{{description}}</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9aa0a6;">Дата создания</td>
            <td style="padding: 6px 0;">{{createdAt}}</td>
          </tr>
        </table>

        <a href="https://yourdomain.com/user/feedback/{{feedbackId}}"
           style="display:inline-block; padding:10px 14px; background:#FF4500; color:#fff; text-decoration:none; border-radius:6px; font-size:13px;">
          Открыть фидбек
        </a>

        <p style="margin-top: 24px; font-size: 12px; color: #777;">
          Это системное уведомление. Отвечать на него не требуется.
        </p>

      </td>
    </tr>
  {{/content}}
{{/extend}}