{{#extend "baseLayout" title="Обновление условий"}}
  {{#content "body"}}
    <tr>
      <td style="
        padding: 28px;
        font-family: Arial, sans-serif;
        background-color: #1A1D24;
        border-radius: 10px;
        color: #ffffff;
      ">

        <h2 style="
          font-size: 20px;
          margin: 0 0 14px 0;
          color: #FF4500;
          font-weight: 600;
        ">
          Обновлены условия использования
        </h2>

        <p style="
          font-size: 14px;
          margin: 0 0 20px 0;
          color: #d1d5db;
          line-height: 1.5;
        ">
          Обновлена следующая документация: {{consentTitle}} (версия {{version}}).
        </p>

        <table style="
          width: 100%;
          font-size: 14px;
          color: #e5e7eb;
          border-collapse: collapse;
          margin-bottom: 18px;
        ">
          <tr>
            <td style="padding: 6px 0; width: 45%; color: #9ca3af;">Версия</td>
            <td style="padding: 6px 0;">{{version}}</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Дата обновления</td>
            <td style="padding: 6px 0;">{{updateDate}}</td>
          </tr>
          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Вступает в силу</td>
            <td style="padding: 6px 0;">{{effectiveDate}}</td>
          </tr>
        </table>

        <div style="
          background-color: #111318;
          padding: 16px;
          border-radius: 8px;
          margin-bottom: 20px;
        ">
          <p style="
            font-size: 14px;
            color: #e5e7eb;
            line-height: 1.6;
            margin: 0;
          ">
            {{changeDescription}}
          </p>
        </div>

        {{#if documentUrl}}
        <div style="text-align: center; margin-bottom: 20px;">
          <a href="{{documentUrl}}"
             style="
              display: inline-block;
              padding: 10px 16px;
              background-color: #FF4500;
              color: #ffffff;
              text-decoration: none;
              border-radius: 6px;
              font-size: 14px;
              font-weight: 500;
             ">
            Открыть документ
          </a>
        </div>
        {{/if}}

        <div style="
          font-size: 12px;
          color: #9ca3af;
          line-height: 1.5;
          border-top: 1px solid #2a2f3a;
          padding-top: 14px;
        ">
          Продолжение использования сервиса после {{effectiveDate}} означает согласие с обновленными условиями.
        </div>

        <div style="
          margin-top: 12px;
          font-size: 12px;
          color: #9ca3af;
        ">
          При несогласии с изменениями вы можете прекратить использование сервиса и удалить аккаунт в настройках профиля.
        </div>

      </td>
    </tr>
  {{/content}}
{{/extend}}