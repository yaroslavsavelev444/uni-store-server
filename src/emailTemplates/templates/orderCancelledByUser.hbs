{{#extend "baseLayout" title="Заказ отменен"}}
  {{#content "body"}}
    <tr>
      <td style="
        padding: 28px;
        font-family: Arial, sans-serif;
        background-color: #1A1D24;
        border-radius: 8px;
      ">

        <h2 style="color: #FF4500; font-size: 20px; margin-bottom: 16px;">
          Заказ отменен
        </h2>

        <p style="color: #e6e6e6; font-size: 14px; margin-bottom: 18px;">
          Заказ №{{orderNumber}} был отменен пользователем.
        </p>

        <table style="
          width: 100%;
          font-size: 14px;
          color: #d1d1d1;
          margin-bottom: 22px;
          border-collapse: collapse;
        ">

          <tr>
            <td style="padding: 6px 0; color: #9aa0a6; width: 180px;">Причина</td>
            <td style="padding: 6px 0;">{{cancellation.reason}}</td>
          </tr>

          <tr>
            <td style="padding: 6px 0; color: #9aa0a6;">Инициатор отмены</td>
            <td style="padding: 6px 0;">{{cancellation.cancelledBy}}</td>
          </tr>

          <tr>
            <td style="padding: 6px 0; color: #9aa0a6;">Дата отмены</td>
            <td style="padding: 6px 0;">{{cancellation.cancelledAt}}</td>
          </tr>

          <tr>
            <td style="padding: 6px 0; color: #9aa0a6;">Сумма заказа</td>
            <td style="padding: 6px 0;">
              {{pricing.total}} {{pricing.currency}}
            </td>
          </tr>

        </table>

        <a href="https://yourdomain.com/orders/{{_id}}"
           style="
             display:inline-block;
             padding:10px 14px;
             background:#FF4500;
             color:#fff;
             text-decoration:none;
             border-radius:6px;
             font-size:13px;
           ">
          Открыть заказ
        </a>

        <p style="margin-top: 22px; font-size: 12px; color: #777;">
          Это системное уведомление. Если вы не выполняли отмену, обратитесь в поддержку.
        </p>

      </td>
    </tr>
  {{/content}}
{{/extend}}