{{#extend "baseLayout" title="Код подтверждения"}}
  {{#content "body"}}

    <tr>
      <td style="
        padding: 24px;
        font-size: 14px;
        color: #1E1E1E;
        line-height: 1.5;
        text-align: center;
      ">

        <h2 style="
          margin: 0 0 16px;
          font-size: 18px;
          font-weight: 600;
        ">
          Код подтверждения
        </h2>

        <p style="margin: 0 0 16px;">
          Используйте код для входа в систему.
        </p>

      </td>
    </tr>

    <!-- Код -->
    <tr>
      <td align="center" style="padding: 0 24px 24px 24px;">

        <div style="
          display: inline-block;
          font-size: 26px;
          font-weight: 700;
          letter-spacing: 6px;
          padding: 16px 24px;
          border: 1px solid #e5e5e5;
          border-radius: 6px;
          font-family: monospace;
          color: #1E1E1E;
        ">
          {{code}}
        </div>

      </td>
    </tr>

    <!-- Срок -->
    <tr>
      <td style="
        padding: 0 24px 16px 24px;
        font-size: 13px;
        color: #666;
        text-align: center;
      ">
        Срок действия: {{expiresInMinutes}} мин.
      </td>
    </tr>

    <!-- Безопасность -->
    <tr>
      <td style="
        padding: 0 24px 24px 24px;
        font-size: 13px;
        color: #666;
        text-align: center;
      ">
        Если вы не выполняли вход, не используйте данный код.
      </td>
    </tr>

  {{/content}}
{{/extend}}