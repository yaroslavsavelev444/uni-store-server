{{#extend "baseLayout" title="Заказ создан"}}
  {{#content "body"}}

    <tr>
      <td style="
        padding: 24px;
        font-size: 14px;
        color: #1E1E1E;
        line-height: 1.5;
      ">

        <h2 style="
          margin: 0 0 16px;
          font-size: 18px;
          font-weight: 600;
        ">
          Заказ создан
        </h2>

        <p style="margin: 0 0 16px;">
          Заказ №{{orderNumber}} успешно создан.
        </p>

      </td>
    </tr>

    <!-- Основные данные -->
    <tr>
      <td style="padding: 0 24px 24px 24px;">

        <table width="100%" cellpadding="0" cellspacing="0"
          style="
            border: 1px solid #e5e5e5;
            border-radius: 6px;
          "
        >

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Заказчик
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              {{customer.name}}
            </td>
          </tr>

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Email
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              {{customer.email}}
            </td>
          </tr>

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Телефон
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              {{customer.phone}}
            </td>
          </tr>

        </table>

      </td>
    </tr>

    <!-- Стоимость -->
    <tr>
      <td style="padding: 0 24px 24px 24px;">

        <table width="100%" cellpadding="0" cellspacing="0"
          style="
            border: 1px solid #e5e5e5;
            border-radius: 6px;
          "
        >

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Сумма
            </td>
            <td style="
              padding: 12px;
              font-size: 14px;
              font-weight: 600;
              text-align: right;
            ">
              {{order.pricing.total}} {{order.pricing.currency}}
            </td>
          </tr>

        </table>

      </td>
    </tr>

    <tr>
      <td style="
        padding: 0 24px 24px 24px;
        font-size: 13px;
        color: #666;
      ">
        Детали заказа доступны в личном кабинете.
      </td>
    </tr>

  {{/content}}
{{/extend}}