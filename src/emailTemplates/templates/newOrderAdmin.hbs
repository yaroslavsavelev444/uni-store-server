{{#extend "baseLayout" title="Новый заказ"}}
  {{#content "body"}}

    <tr>
      <td style="
        padding: 24px;
        font-size: 14px;
        color: #1E1E1E;
        line-height: 1.5;
      ">

        <h2 style="
          margin: 0 0 16px;
          font-size: 18px;
          font-weight: 600;
        ">
          Новый заказ
        </h2>

        <p style="margin: 0 0 16px;">
          Зафиксировано создание нового заказа.
        </p>

      </td>
    </tr>

    <!-- Данные заказа -->
    <tr>
      <td style="padding: 0 24px 24px 24px;">

        <table width="100%" cellpadding="0" cellspacing="0"
          style="
            border: 1px solid #e5e5e5;
            border-radius: 6px;
          "
        >

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Номер заказа
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              №{{orderNumber}}
            </td>
          </tr>

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Клиент
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              {{customer.name}}
            </td>
          </tr>

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Email
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              {{customer.email}}
            </td>
          </tr>

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Телефон
            </td>
            <td style="padding: 12px; font-size: 13px; text-align: right;">
              {{customer.phone}}
            </td>
          </tr>

        </table>

      </td>
    </tr>

    <!-- Сумма -->
    <tr>
      <td style="padding: 0 24px 24px 24px;">

        <table width="100%" cellpadding="0" cellspacing="0"
          style="
            border: 1px solid #e5e5e5;
            border-radius: 6px;
          "
        >

          <tr>
            <td style="padding: 12px; font-size: 13px; color: #666;">
              Сумма
            </td>
            <td style="
              padding: 12px;
              font-size: 14px;
              font-weight: 600;
              text-align: right;
            ">
              {{orderData.pricing.total}} {{orderData.pricing.currency}}
            </td>
          </tr>

        </table>

      </td>
    </tr>

    {{> button 
      link=(concat "https://yourdomain.com/admin/orders/" orderData._id) 
      text="Открыть заказ"
    }}

  {{/content}}
{{/extend}}