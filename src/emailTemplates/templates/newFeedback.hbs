{{#extend "baseLayout" title="Новый фидбек"}}
  {{#content "body"}}
    <tr>
      <td style="
        padding: 28px;
        font-family: Arial, sans-serif;
        background-color: #1A1D24;
        border-radius: 10px;
        color: #ffffff;
      ">

        <h2 style="
          font-size: 20px;
          margin: 0 0 14px 0;
          color: #FF4500;
          font-weight: 600;
        ">
          Новый фидбек
        </h2>

        <p style="
          font-size: 14px;
          margin: 0 0 18px 0;
          color: #d1d5db;
          line-height: 1.5;
        ">
          Поступил новый пользовательский фидбек.
        </p>

        <table style="
          width: 100%;
          font-size: 14px;
          color: #e5e7eb;
          border-collapse: collapse;
          margin-bottom: 18px;
        ">
          <tr>
            <td style="padding: 6px 0; width: 40%; color: #9ca3af;">ID</td>
            <td style="padding: 6px 0;">{{feedbackId}}</td>
          </tr>

          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Название</td>
            <td style="padding: 6px 0;">{{title}}</td>
          </tr>

          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Тип</td>
            <td style="padding: 6px 0;">{{type}}</td>
          </tr>

          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Пользователь</td>
            <td style="padding: 6px 0;">{{userName}} ({{userEmail}})</td>
          </tr>

          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Приоритет</td>
            <td style="padding: 6px 0;">{{priority}}</td>
          </tr>

          <tr>
            <td style="padding: 6px 0; color: #9ca3af;">Дата</td>
            <td style="padding: 6px 0;">{{createdAt}}</td>
          </tr>
        </table>

        <div style="
          background-color: #111318;
          padding: 16px;
          border-radius: 8px;
          margin-bottom: 18px;
        ">
          <div style="
            font-size: 12px;
            color: #9ca3af;
            margin-bottom: 8px;
          ">
            Описание
          </div>

          <div style="
            font-size: 14px;
            color: #e5e7eb;
            line-height: 1.6;
            white-space: pre-wrap;
          ">
            {{description}}
          </div>
        </div>

        <div style="
          font-size: 12px;
          color: #9ca3af;
          border-top: 1px solid #2a2f3a;
          padding-top: 14px;
        ">
          Системное уведомление. Ответ на это письмо не требуется.
        </div>

      </td>
    </tr>
  {{/content}}
{{/extend}}