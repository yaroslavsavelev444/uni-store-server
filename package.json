{
  "name": "uni-store-server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "biome check --write --unsafe . && tsc",
    "start": "node dist/index.js",
    "check": "biome check .",
    "fix": "biome check --write --unsafe .",
    "lint": "biome lint .",
    "type:check": "tsc --noEmit",
    "check:all": "npm run check && npm run type:check",
    "clean": "rm -rf node_modules package-lock.json dist && npm install"
  },
  "dependencies": {
    "@bull-board/api": "^6.9.2",
    "@bull-board/express": "^6.9.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.0",
    "bull": "^4.16.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-handlebars": "^8.0.1",
    "express-rate-limit": "^7.5.0",
    "express-slow-down": "^2.1.0",
    "express-useragent": "^2.0.2",
    "express-validator": "^7.2.1",
    "fs-extra": "^11.3.3",
    "handlebars": "^4.7.8",
    "handlebars-layouts": "^3.1.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "juice": "^11.0.1",
    "moment": "^2.30.1",
    "mongodb": "^6.16.0",
    "mongoose": "^8.14.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.7",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.0.0",
    "sanitize-filename": "^1.6.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "transliteration": "^2.3.5",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.17",
    "@types/validator": "^13.15.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
